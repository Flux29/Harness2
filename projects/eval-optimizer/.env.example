# eval-optimizer configuration TEMPLATE. Copy to .env and adjust.
# Secrets (NVIDIA_API_KEY, OPENROUTER_API_KEY, LOGFIRE_TOKEN) belong in
# Windows USER environment variables (setx), not here.

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
GLM_MODEL=z-ai/glm-5.2
PLANNER_MODEL=openrouter:z-ai/glm-5.2
GENERATOR_MODEL=openrouter:z-ai/glm-5.2
CRITIC_MODEL=openrouter:z-ai/glm-5.2
OLLAMA_BASE_URL=http://localhost:11435
EMBED_MODEL=mxbai-embed-large
EMBED_DIM=1024
DATABASE_URL=postgresql://agentic:agentic@localhost:5433/agentic

# Phase 5.2 (crit-fork-exec-gate): the fork engine (run_forked_viability,
# fork_check) writes LLM-generated code and runs its pytest suite ON THIS
# HOST. It refuses to run without this explicit acknowledgment — set it only
# on a machine you trust with generated code:
# EVALOPT_ALLOW_HOST_EXEC=1
