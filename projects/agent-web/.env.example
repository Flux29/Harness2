# agent-web configuration TEMPLATE. Copy to .env and adjust.
# SECRETS DO NOT GO HERE — set them as Windows USER environment variables:
#   setx OPENROUTER_API_KEY "..."     (model access)
#   setx GITHUB_MCP_PAT "..."        (GitHub MCP; fine-grained PAT recommended)
#   setx LOGFIRE_TOKEN "..."         (trace WRITE token)
#   setx LOGFIRE_READ_TOKEN "..."    (logfire-mcp READ token)

AGENT_MODEL=openrouter:z-ai/glm-5.2
# FALLBACK_MODEL=openrouter:deepseek/deepseek-chat
MCP_ENABLE=context7,deepwiki,github,logfire
# COST_BUDGET_USD=5

# Optional: the `postgres` MCP server (mcp.json) needs DATABASE_URL. Bring up the
# pgvector stack in ../../infra/ first, then add `postgres` to MCP_ENABLE above.
# Non-secret connection string (local dev creds), so it may live in .env:
# DATABASE_URL=postgresql://agentic:agentic@localhost:5433/agentic

# Feature switches (ADR-0015): 0=off. EXECUTE is approval-gated; browser is NOT.
TEAMS=0
TOOL_SEARCH=0
EXECUTE=0
BROWSER_AUTOMATION=0
LITEPARSE=0
IMPROVE=0
