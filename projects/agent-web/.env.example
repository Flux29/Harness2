# agent-web configuration TEMPLATE. Copy to .env and adjust.
# SECRETS DO NOT GO HERE — set them as Windows USER environment variables:
#   setx OPENROUTER_API_KEY "..."     (model access)
#   setx GITHUB_MCP_PAT "..."        (GitHub MCP; fine-grained PAT recommended)
#   setx LOGFIRE_TOKEN "..."         (trace WRITE token)
#   setx LOGFIRE_READ_TOKEN "..."    (logfire-mcp READ token)

AGENT_MODEL=openrouter:z-ai/glm-5.2
# Phase 5.1 — history migration window (upgrading a v1 deployment ONLY):
# authoritative history now lives in STATE_DIR/history/ (server-only; agents
# cannot read it). Set HISTORY_DUAL_WRITE=1 for the parallel-run window, run
# >=5 clean sessions (state/history/_divergences.log stays empty), then REMOVE
# the flag. Deadline: the Gate 4 allowlist expiry (2026-08-15). Fresh installs
# leave both unset.
# STATE_DIR=state
# HISTORY_DUAL_WRITE=1
# FALLBACK_MODEL=openrouter:deepseek/deepseek-chat
MCP_ENABLE=context7,deepwiki,github,logfire

# Security posture (ADR-0020). The service binds loopback and guards POST /agent
# (JSON content-type + Origin + loopback Host). AGENT_TOKEN is optional for the
# single-user loopback baseline and REQUIRED if you bind beyond 127.0.0.1
# (set it as a USER env var, not here). REQUIRE_LOOPBACK_HOST=1 is the default.
#   setx AGENT_TOKEN "..."     (bearer token for POST /agent; needed off-loopback)
# CORS_ORIGINS=http://localhost:3000
# REQUIRE_LOOPBACK_HOST=1
# COST_BUDGET_USD=5

# Optional: the `postgres` MCP server (mcp.json) needs DATABASE_URL. Bring up the
# pgvector stack in ../../infra/ first, then add `postgres` to MCP_ENABLE above.
# Non-secret connection string (local dev creds), so it may live in .env:
# DATABASE_URL=postgresql://agentic:agentic@localhost:5433/agentic

# Feature switches (ADR-0015): 0=off. EXECUTE is approval-gated; browser is NOT.
TEAMS=0
TOOL_SEARCH=0
EXECUTE=0
BROWSER_AUTOMATION=0
LITEPARSE=0
IMPROVE=0
